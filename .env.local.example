# ── Required ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/assay
OPENAI_API_KEY=sk-...                    # For embeddings (text-embedding-3-small)
                                          # Not needed if EMBEDDING_PROVIDER=local

# ── Notion (optional — for workspace ingestion) ──────────────────
NOTION_API_KEY=ntn_...

# ── Extraction Mode ──────────────────────────────────────────────
EXTRACTION_MODE=ollama                   # ollama | anthropic | subagent
OLLAMA_URL=http://localhost:11434        # Only for mode=ollama
OLLAMA_MODEL=phi4:14b                    # Only for mode=ollama
ANTHROPIC_API_KEY=sk-ant-...             # Only needed for mode=anthropic extraction

# ── Embedding Provider ───────────────────────────────────────────
EMBEDDING_PROVIDER=openai                # openai (default, 1536d) | local (ONNX bge-large, 1024d)
                                          # Local: npm install @xenova/transformers
                                          # Local runs on-device — no API key needed for embeddings
                                          # Optimized for Apple Silicon (M1/M2/M3/M4)

# ── Optional ─────────────────────────────────────────────────────
PRODUCT_ID=                              # Auto-generated during setup if empty
STRESS_TEST_MAX_EVIDENCE=100             # Max evidence records for stress_test (default: 100)

# ── Confluence (optional) ────────────────────────────────────────
# CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki
# CONFLUENCE_EMAIL=you@company.com
# CONFLUENCE_API_TOKEN=...
